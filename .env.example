# FBCH Meeting Scheduler — environment variables
#
# Local dev:   cp .env.example .env   and fill in values.
# Production:  set the same variables on the Railway service
#              (Railway also injects PORT and RAILWAY_PUBLIC_DOMAIN itself).

# ──────────────────────────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string. On Railway, attach a Postgres database
# and reference it: ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Signs session + passkey-challenge cookies. Min 16 chars — make it long
# and random (e.g. run: openssl rand -base64 32)
SESSION_SECRET="CHANGE_ME_to_a_long_random_string"

# ──────────────────────────────────────────────────────────────────
# FIRST DEPLOY — bootstrap admin (used only while the database is empty)
# Sign in once with this email + passcode, then set up a passkey.
# ──────────────────────────────────────────────────────────────────

BOOTSTRAP_ADMIN_EMAIL="wade@piercesales.com"
BOOTSTRAP_ADMIN_PASSCODE="CHANGE_ME_one_time_passcode"
BOOTSTRAP_ADMIN_NAME="Wade Pierce"

# ──────────────────────────────────────────────────────────────────
# RECOMMENDED
# ──────────────────────────────────────────────────────────────────

# Absolute origin used in invite links and texted RSVP links.
# Must match the public URL people actually open. Until the custom domain is
# ready, use the Railway default host (not meetings.fbchenrietta.org).
APP_URL="https://fbch-meeting-scheduler-production.up.railway.app"

# ──────────────────────────────────────────────────────────────────
# EMAIL — invites + per-organizer notifications (Resend free tier)
# 1. resend.com → Domains → add fbchenrietta.org and create the DNS
#    records it shows (SPF + DKIM). Wait for "Verified".
# 2. resend.com → API Keys → create a key (starts with "re_").
# SMTP_USER is literally the word "resend"; the API key is the password.
# Leave unset to disable email — the app still works (copy links instead).
# ──────────────────────────────────────────────────────────────────

SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_YOUR_RESEND_API_KEY"
# Port 465 is implicit TLS (auto-detected); leave this false.
SMTP_SECURE="false"
EMAIL_FROM="FBCH Scheduler <meetings@fbchenrietta.org>"

# ──────────────────────────────────────────────────────────────────
# PLANNING CENTER — Events page (optional)
# Create a Personal Access Token at:
#   https://api.planningcenteronline.com/oauth/applications
# Leave unset to hide the calendar pull — manual headcounts still work.
# ──────────────────────────────────────────────────────────────────

PCO_APP_ID="YOUR_PCO_APPLICATION_ID"
PCO_SECRET="YOUR_PCO_SECRET"

# ──────────────────────────────────────────────────────────────────
# ADVANCED — rarely needed
# ──────────────────────────────────────────────────────────────────

# WebAuthn Relying Party ID. Defaults to the request hostname. Only set when
# passkeys must span multiple subdomains AND every host is under that parent
# (e.g. RP_ID=fbchenrietta.org for app.fbchenrietta.org). Leave unset while
# using the Railway *.up.railway.app host — a custom-domain RP_ID there
# breaks passkeys with "RP ID is invalid for this domain".
# RP_ID="fbchenrietta.org"

# Override the Planning Center API host (used by tests with a mock server).
# PCO_BASE_URL="https://api.planningcenteronline.com"
