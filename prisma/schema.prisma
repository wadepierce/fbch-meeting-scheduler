generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Invited organizers (staff/committee) who can create polls
model Organizer {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  /// Optional legacy passcode. Passkey users have none.
  passcodeHash String?
  active       Boolean      @default(true)
  isAdmin      Boolean      @default(false)
  /// Self-service email notification preferences
  notifyPollResponses Boolean @default(true)
  notifyRsvpReplies   Boolean @default(true)
  /// Show the first-run walkthrough tour (self-service; re-enable on Account)
  showTour            Boolean @default(true)
  /// Last successful sign-in (passkey, passcode, or invite link)
  lastSignedInAt      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  polls        Meeting[]
  credentials  Credential[]
  invitesSent  Invite[]     @relation("InvitedBy")
  quickPolls   Poll[]       @relation("PollCreator")
}

/// A WebAuthn / passkey credential bound to an organizer.
/// One organizer can have several (phone, laptop, security key…).
model Credential {
  id           String    @id @default(cuid())
  organizerId  String
  organizer    Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  /// base64url-encoded credential id from the authenticator
  credentialId String    @unique
  /// COSE public key bytes
  publicKey    Bytes
  counter      Int       @default(0)
  transports   String[]  @default([])
  deviceLabel  String?
  backedUp     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime  @default(now())

  @@index([organizerId])
}

/// A single-use-ish invite link. Clicking it signs the person in and
/// (the first time) provisions their Organizer record.
model Invite {
  id          String     @id @default(cuid())
  token       String     @unique
  email       String
  name        String
  isAdmin     Boolean    @default(false)
  invitedById String?
  invitedBy   Organizer? @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  organizerId String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())

  @@index([email])
}

model Meeting {
  id                  String             @id @default(cuid())
  slug                String             @unique
  title               String
  description         String?
  status              MeetingStatus      @default(DRAFT)
  timezone            String             @default("America/Chicago")
  slotMinutes         Int                @default(30)
  startTime           String
  endTime             String
  dates               String[]
  durationHintMinutes Int?
  createdById         String?
  createdBy           Organizer?         @relation(fields: [createdById], references: [id], onDelete: SetNull)

  chosenSlotKey       String?
  meetingDurationMin  Int?
  meetingSubject      String?
  meetingBody         String?            @db.Text
  meetingLocation     String?
  finalizedAt         DateTime?
  /// Public /m/{slug} page opens (bots/link previews excluded)
  viewCount           Int                @default(0)

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  responses           MeetingResponse[]

  @@index([status])
  @@index([createdById])
}

model MeetingResponse {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  guestToken  String?
  displayName String
  email       String?
  slots       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([meetingId, guestToken])
  @@index([meetingId])
}

enum MeetingStatus {
  DRAFT
  ACTIVE
  CLOSED
}

/// A headcount / RSVP page for an event — usually created from a
/// Planning Center calendar event, or entered manually.
model Rsvp {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String?        @db.Text
  location      String?
  startsAt      DateTime
  endsAt        DateTime?
  timezone      String         @default("America/Chicago")
  status        RsvpStatus     @default(OPEN)
  pcoEventId    String?
  pcoInstanceId String?
  createdById   String?
  /// Public /r/{slug} page opens (bots/link previews excluded)
  viewCount     Int            @default(0)
  /// Per-person text template. Tokens: %first% %last% %name% %event% %when% %where% %link%
  messageTemplate String?      @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  responses     RsvpResponse[]
  invitees      RsvpInvitee[]

  @@index([status])
  @@index([startsAt])
}

/// Someone the organizer is texting a personal headcount link to.
/// Filled manually or imported from a Planning Center People list.
model RsvpInvitee {
  id            String        @id @default(cuid())
  rsvpId        String
  rsvp          Rsvp          @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  /// Planning Center People id (optional until list import)
  pcoPersonId   String?
  firstName     String
  lastName      String        @default("")
  displayName   String
  /// Phone as entered / from PCO (any format; normalized when building sms:)
  phone         String?
  /// Unguessable token for /r/{slug}/t/{token}
  token         String        @unique
  /// Organizer tapped Text (or marked texted)
  textedAt      DateTime?
  firstOpenedAt DateTime?
  lastOpenedAt  DateTime?
  openCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  response      RsvpResponse?

  @@index([rsvpId])
  @@index([pcoPersonId])
}

model RsvpResponse {
  id          String        @id @default(cuid())
  rsvpId      String
  rsvp        Rsvp          @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  /// Device cookie for anonymous / shared-link replies. Invitee replies use inv:{id}.
  guestToken  String
  displayName String
  answer      RsvpAnswer
  /// How many people this response covers (family/party size)
  count       Int           @default(1)
  note        String?
  /// When set, this reply belongs to a roster invitee (personal link)
  inviteeId   String?       @unique
  invitee     RsvpInvitee?  @relation(fields: [inviteeId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([rsvpId, guestToken])
  @@index([rsvpId])
}

enum RsvpStatus {
  OPEN
  CLOSED
}

enum RsvpAnswer {
  YES
  MAYBE
  NO
}

/// A quick question poll (ratings, scales, this-or-that, choices) shared by link.
model Poll {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  description  String?        @db.Text
  status       PollStatus     @default(OPEN)
  /// Show tallies to voters after they answer
  showResults  Boolean        @default(true)
  /// Ask voters for their name (off = anonymous)
  collectNames Boolean        @default(true)
  createdById  String?
  createdBy    Organizer?     @relation("PollCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Public /p/{slug} page opens (bots/link previews excluded)
  viewCount    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  questions    PollQuestion[]
  votes        PollVote[]

  @@index([status])
}

model PollQuestion {
  id       String           @id @default(cuid())
  pollId   String
  poll     Poll             @relation(fields: [pollId], references: [id], onDelete: Cascade)
  order    Int
  kind     PollQuestionKind
  prompt   String
  /// CHOICE / MULTI / THIS_OR_THAT options
  options  String[]         @default([])
  /// RATING: 1..scaleMax stars. SCALE: scaleMin..scaleMax.
  scaleMin Int?
  scaleMax Int?
  minLabel String?
  maxLabel String?
  /// Allow a write-in "Other" answer (CHOICE / MULTI)
  allowOther Boolean        @default(false)
  answers  PollAnswer[]

  @@index([pollId])
}

/// One ballot per device (guest cookie) per poll — prevents double voting
/// while letting the same person edit their answers.
model PollVote {
  id          String       @id @default(cuid())
  pollId      String
  poll        Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  guestToken  String
  displayName String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  answers     PollAnswer[]

  @@unique([pollId, guestToken])
  @@index([pollId])
}

model PollAnswer {
  id         String       @id @default(cuid())
  voteId     String
  vote       PollVote     @relation(fields: [voteId], references: [id], onDelete: Cascade)
  questionId String
  question   PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  /// Selected option indexes (choice kinds)
  selections Int[]        @default([])
  /// Numeric answer (RATING / SCALE)
  value      Int?
  /// Write-in text when "Other" was chosen
  otherText  String?

  @@unique([voteId, questionId])
  @@index([questionId])
}

enum PollStatus {
  OPEN
  CLOSED
}

enum PollQuestionKind {
  CHOICE
  MULTI
  THIS_OR_THAT
  RATING
  SCALE
}
